FROM python:3.11-slim

WORKDIR /app

COPY shared/ /app/shared/
COPY requirements.txt /app/requirements.txt 2>/dev/null || true

RUN pip install --no-cache-dir fastapi uvicorn sqlalchemy asyncpg httpx pyjwt python-multipart -i https://pypi.tuna.tsinghua.edu.cn/simple

COPY . /app/

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
