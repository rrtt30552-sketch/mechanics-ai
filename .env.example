# MechAI Environment Variables
# 至少配置一个模型的 API Key 即可使用

# ========== AI 模型 API Keys (至少配一个) ==========

# 小米 MiMo - https://mimo.xiaomi.com
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# DeepSeek - https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问 (Qwen) - https://dashscope.console.aliyun.com
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI (可选)
OPENAI_API_KEY=

# ========== 系统配置 ==========

# JWT Secret (⚠️ 生产环境必须修改！)
JWT_SECRET=mechai-dev-secret-change-in-production

# Database (Docker 内部连接，一般不需要改)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mech_ai
REDIS_URL=redis://redis:6379/0

# MinIO (文件存储)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# CORS (逗号分隔，生产环境设为你的域名)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ========== Embedding 配置 ==========

# 自定义 embedding 模型 (默认自动选择)
# 优先级: 自定义 > bge-base-zh-v1.5 > m3e-base > all-MiniLM-L6-v2
# EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5

# ========== 限流配置 ==========

# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_BURST=10

# ========== 环境标识 ==========

# ENV=production  (生产环境会强制校验 JWT_SECRET)
