# MechAI Environment Variables
# 至少配置一个模型的 API Key 即可使用

# ========== AI 模型 API Keys (至少配一个) ==========

# MiMo (小米大模型) - https://mimo.xiaomi.com
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# DeepSeek - https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问 (Qwen) - https://dashscope.console.aliyun.com
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI (可选)
OPENAI_API_KEY=

# ========== 系统配置 ==========

# JWT Secret (生产环境请修改)
JWT_SECRET=mechai-dev-secret-change-in-production

# Database (Docker 内部连接，一般不需要改)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mech_ai
REDIS_URL=redis://redis:6379/0

# MinIO (文件存储)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
