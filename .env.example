# MechAI Environment Variables

# DeepSeek API (必需)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# JWT Secret (生产环境请修改)
JWT_SECRET=mechai-dev-secret-change-in-production

# Database (Docker 内部连接，一般不需要改)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mech_ai
REDIS_URL=redis://redis:6379/0

# MinIO (文件存储)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
